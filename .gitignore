# Dependencies
node_modules/

# Build output (root-level TypeScript compilation only, not frontend/dist)
/dist/

# Database files
*.db
*.db-shm
*.db-wal

# Chroma storage
chroma/

# Logs
*.log

# Environment
.env
.env.local
.env.production
.env.staging
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temporary files
tmp/
.tmp/

# Test coverage
coverage/

# Test artifacts
playwright-report/
test-results/
*.pid

# Local Cloudflare Wrangler state
.wrangler/

# Oracle instance data (per-user vault; never commit)
ψ/

# Generated report files (use oracle-vault-report repo instead)
vault-report.html
vault-repos.html
vault-data.json

services/**/__pycache__/
services/**/*.pyc

# Codex agent worktrees (git worktree, registered in .git/worktrees — not tracked)
agents/

# Per-machine maw state (engine map differs per oracle — committing clashes)
.maw/
.envrc

# omx per-session project memory (not source of truth)
.omx/

# volt-oracle per-machine tooling artifacts (not source of truth)
.volt/

# macOS metadata
.DS_Store

# Playwright MCP session artifacts
.playwright-mcp/

# Cloudflare local dev state
.wrangler/
