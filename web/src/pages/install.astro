---
import Base from "../layouts/Base.astro";

const STEPS = [
  {
    n: 1,
    title: "Backend — start the MCP server",
    cmd: "bunx --bun arra-oracle-v3@github:Soul-Brews-Studio/arra-oracle-v3",
    after: "Listens on http://localhost:47778. Leave it running.",
  },
  {
    n: 2,
    title: "UI — open Oracle Studio (in a new terminal)",
    cmd: "bunx --bun oracle-studio@github:Soul-Brews-Studio/oracle-studio",
    after: "Opens http://localhost:3000 with a dashboard proxying to the backend.",
  },
  {
    n: 3,
    title: "CLI — drive the Oracle from your shell",
    cmd: "bunx --bun arra-oracle@github:Soul-Brews-Studio/arra-oracle-v3 search \"hybrid search\"",
    after: "15 MCP tools wrapped: search, learn, list, trace, stats, threads, supersede, schedule…",
  },
];
---

<Base title="Install — Neo ARRA V3">
  <main class="max-w-4xl mx-auto px-6 py-20">
    <div class="mb-12">
      <a href="/" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">← home</a>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight mt-4 mb-4 bg-gradient-to-b from-white to-gray-400 bg-clip-text text-transparent">
        Install
      </h1>
      <p class="text-gray-400 text-lg">
        Three <code class="text-teal-400">bunx</code> commands. No clone, no npm publish, no pain.
        Requires <a href="https://bun.sh" class="text-teal-400 hover:text-teal-300">Bun ≥ 1.2</a>.
      </p>
    </div>

    <div class="space-y-8">
      {STEPS.map((s) => (
        <div class="bg-gray-900/80 border border-gray-800 rounded-xl p-6">
          <div class="flex items-start gap-4 mb-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-teal-500/20 border border-teal-400/40 text-teal-300 font-mono text-sm flex items-center justify-center">
              {s.n}
            </span>
            <h2 class="text-xl font-semibold">{s.title}</h2>
          </div>
          <div class="relative">
            <pre class="bg-black/60 border border-gray-800 rounded-lg p-4 overflow-x-auto text-sm text-teal-300 font-mono"><code>{s.cmd}</code></pre>
            <button
              data-copy={s.cmd}
              class="absolute top-2 right-2 text-xs bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-teal-300 px-3 py-1 rounded transition-colors"
            >
              copy
            </button>
          </div>
          <p class="text-gray-500 text-sm mt-3">{s.after}</p>
        </div>
      ))}
    </div>

    <div class="mt-16 bg-gray-900/60 border border-gray-800 rounded-xl p-6">
      <h2 class="text-lg font-semibold mb-2">Then try</h2>
      <ul class="text-gray-400 text-sm space-y-2">
        <li>• Open <a href="/canvas/?plugin=graph3d" class="text-teal-400 hover:text-teal-300">/canvas</a> — 6 ESM plugins mount on one Three.js host</li>
        <li>• Visit <a href="https://studio.buildwithoracle.com" class="text-teal-400 hover:text-teal-300">studio.buildwithoracle.com</a> (static preview; real app via <code>bunx oracle-studio</code>)</li>
        <li>• <code class="text-teal-300">bunx --bun arra-oracle@... --help</code> — list all 15 CLI commands</li>
      </ul>
    </div>
  </main>

  <script>
    document.querySelectorAll<HTMLButtonElement>("button[data-copy]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const text = btn.dataset.copy ?? "";
        try {
          await navigator.clipboard.writeText(text);
          const orig = btn.textContent;
          btn.textContent = "copied ✓";
          btn.classList.add("text-teal-300");
          setTimeout(() => {
            btn.textContent = orig;
            btn.classList.remove("text-teal-300");
          }, 1500);
        } catch {
          btn.textContent = "select + copy";
        }
      });
    });
  </script>
</Base>
