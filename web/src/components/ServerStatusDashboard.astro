---
const defaultApi = import.meta.env.PUBLIC_BACKEND_URL ?? "http://localhost:47778";
---

<section
  id="server-status-dashboard"
  data-default-api={defaultApi}
  class="space-y-6"
  aria-live="polite"
>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-mono uppercase tracking-widest text-teal-400">Runtime status</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-white">Server status dashboard</h1>
      <p class="mt-3 max-w-2xl text-gray-400">
        Checks the local Elysia API, registered plugin server manifests, and vector database adapter health.
      </p>
    </div>
    <button
      id="status-refresh"
      class="rounded-lg border border-teal-700/70 bg-teal-500/10 px-4 py-2 text-sm font-semibold text-teal-200 transition-colors hover:bg-teal-500/20"
      type="button"
    >
      Refresh
    </button>
  </div>

  <div class="rounded-xl border border-gray-800 bg-gray-900/70 p-4 text-sm text-gray-400">
    API target: <code id="status-api-target" class="text-teal-300">checking…</code>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <article class="rounded-xl border border-gray-800 bg-gray-900/80 p-5 shadow-lg shadow-black/10">
      <div class="mb-5 flex items-start justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold text-white">Elysia health</h2>
          <p class="mt-1 text-sm text-gray-500">GET /api/health</p>
        </div>
        <span id="server-badge" class="status-badge status-wait">checking</span>
      </div>
      <p id="server-summary" class="mb-4 text-sm text-gray-300">Waiting for server response…</p>
      <div id="server-details" class="space-y-2 text-sm text-gray-400"></div>
    </article>

    <article class="rounded-xl border border-gray-800 bg-gray-900/80 p-5 shadow-lg shadow-black/10">
      <div class="mb-5 flex items-start justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold text-white">Plugin servers</h2>
          <p class="mt-1 text-sm text-gray-500">GET /api/plugins</p>
        </div>
        <span id="plugins-badge" class="status-badge status-wait">checking</span>
      </div>
      <p id="plugins-summary" class="mb-4 text-sm text-gray-300">Reading plugin registry…</p>
      <div id="plugins-details" class="space-y-3 text-sm text-gray-400"></div>
    </article>

    <article class="rounded-xl border border-gray-800 bg-gray-900/80 p-5 shadow-lg shadow-black/10">
      <div class="mb-5 flex items-start justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold text-white">Vector DB</h2>
          <p class="mt-1 text-sm text-gray-500">GET /api/vector/health</p>
        </div>
        <span id="vector-badge" class="status-badge status-wait">checking</span>
      </div>
      <p id="vector-summary" class="mb-4 text-sm text-gray-300">Checking vector adapter…</p>
      <div id="vector-details" class="space-y-2 text-sm text-gray-400"></div>
    </article>
  </div>
</section>

<style>
  .status-badge {
    border-radius: 9999px;
    border-width: 1px;
    padding: 0.25rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1rem;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .status-ok { border-color: rgb(20 184 166 / 0.7); background: rgb(20 184 166 / 0.12); color: rgb(94 234 212); }
  .status-warn { border-color: rgb(245 158 11 / 0.7); background: rgb(245 158 11 / 0.12); color: rgb(252 211 77); }
  .status-down { border-color: rgb(239 68 68 / 0.7); background: rgb(239 68 68 / 0.12); color: rgb(252 165 165); }
  .status-wait { border-color: rgb(75 85 99 / 0.8); background: rgb(31 41 55 / 0.7); color: rgb(209 213 219); }
</style>

<script>
  const root = document.getElementById("server-status-dashboard");
  const target = document.getElementById("status-api-target");
  const refresh = document.getElementById("status-refresh");
  const fromQuery = new URLSearchParams(window.location.search).get("api")?.trim();
  const fromStorage = localStorage.getItem("NEO_ARRA_API")?.trim();
  const fallback = root?.dataset.defaultApi?.trim() || "http://localhost:47778";
  const apiBase = (fromQuery || fromStorage || fallback).replace(/\/+$/, "");
  if (fromQuery) localStorage.setItem("NEO_ARRA_API", fromQuery);
  if (target) target.textContent = apiBase;

  const isRecord = (value) => value && typeof value === "object" && !Array.isArray(value);
  const text = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = value; };
  const badge = (id, label, state) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = label;
    el.className = `status-badge status-${state}`;
  };
  const clear = (id) => {
    const el = document.getElementById(id);
    if (el) el.replaceChildren();
    return el;
  };
  const row = (label, value) => {
    const p = document.createElement("p");
    const k = document.createElement("span");
    const v = document.createElement("span");
    k.className = "text-gray-500";
    k.textContent = `${label}: `;
    v.className = "text-gray-300";
    v.textContent = value;
    p.append(k, v);
    return p;
  };
  const fetchJson = async (path) => {
    const controller = new AbortController();
    const timer = window.setTimeout(() => controller.abort(), 5000);
    try {
      const response = await fetch(`${apiBase}${path}`, { signal: controller.signal });
      const data = await response.json().catch(() => ({}));
      return { ok: response.ok, status: response.status, data };
    } catch (error) {
      return { ok: false, status: 0, data: { error: error instanceof Error ? error.message : "unreachable" } };
    } finally {
      window.clearTimeout(timer);
    }
  };

  async function loadServer() {
    badge("server-badge", "checking", "wait");
    const result = await fetchJson("/api/health");
    const data = isRecord(result.data) ? result.data : {};
    const ok = result.ok && data.status === "ok";
    badge("server-badge", ok ? "online" : "down", ok ? "ok" : "down");
    text("server-summary", ok ? "Elysia is responding normally." : `Health check failed (${result.status || "network"}).`);
    const details = clear("server-details");
    if (!details) return;
    details.append(
      row("status", String(data.status ?? "unknown")),
      row("server", String(data.server ?? "unknown")),
      row("version", String(data.version ?? "unknown")),
      row("port", String(data.port ?? "unknown")),
      row("oracle", String(data.oracle ?? "unknown")),
    );
    if (data.error) details.append(row("error", String(data.error)));
  }

  async function loadPlugins() {
    badge("plugins-badge", "checking", "wait");
    const result = await fetchJson("/api/plugins");
    const data = isRecord(result.data) ? result.data : {};
    const plugins = Array.isArray(data.plugins) ? data.plugins.filter(isRecord) : [];
    const servers = plugins.filter((plugin) => isRecord(plugin.server));
    const ok = result.ok;
    badge("plugins-badge", ok ? `${servers.length} server${servers.length === 1 ? "" : "s"}` : "down", ok ? "ok" : "down");
    text("plugins-summary", ok ? `${plugins.length} plugins registered; ${servers.length} declare local servers.` : `Plugin registry failed (${result.status || "network"}).`);
    const details = clear("plugins-details");
    if (!details) return;
    if (!ok) {
      details.append(row("error", String(data.error ?? "unreachable")));
      return;
    }
    if (!servers.length) {
      details.append(row("server manifests", "none registered"));
      return;
    }
    servers.slice(0, 5).forEach((plugin) => {
      const server = isRecord(plugin.server) ? plugin.server : {};
      const box = document.createElement("div");
      box.className = "rounded-lg border border-gray-800 bg-gray-950/50 p-3";
      box.append(
        row("plugin", String(plugin.name ?? "unnamed")),
        row("command", [server.command, ...(Array.isArray(server.args) ? server.args : [])].filter(Boolean).join(" ") || "unknown"),
        row("health", String(server.healthPath ?? "not declared")),
        row("autostart", String(server.autostart ?? false)),
      );
      details.append(box);
    });
  }

  async function loadVector() {
    badge("vector-badge", "checking", "wait");
    const result = await fetchJson("/api/vector/health");
    const data = isRecord(result.data) ? result.data : {};
    const status = String(data.status ?? "down");
    const ok = result.ok && status === "ok";
    const warn = result.ok && status === "degraded";
    badge("vector-badge", status, ok ? "ok" : warn ? "warn" : "down");
    text("vector-summary", ok ? "Vector database adapter is healthy." : `Vector status is ${status}.`);
    const details = clear("vector-details");
    if (!details) return;
    details.append(row("checked", String(data.checked_at ?? "unknown")));
    if (data.proxy) details.append(row("proxy", String(data.proxy)));
    if (data.error) details.append(row("error", String(data.error)));
    const engines = Array.isArray(data.engines) ? data.engines.filter(isRecord) : [];
    if (!engines.length) details.append(row("engines", "none reported"));
    engines.slice(0, 5).forEach((engine) => {
      const name = engine.name ?? engine.engine ?? engine.provider ?? "engine";
      const state = engine.status ?? (engine.ok === false ? "down" : "ok");
      details.append(row(String(name), String(engine.error ?? state)));
    });
  }

  async function loadAll() {
    await Promise.all([loadServer(), loadPlugins(), loadVector()]);
  }

  refresh?.addEventListener("click", loadAll);
  loadAll();
</script>
